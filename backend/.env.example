# Anthropic (chat generation)
ANTHROPIC_API_KEY=sk-ant-...
# Model used for answer generation. Defaults to Claude Opus 4.8.
CHAT_MODEL=claude-opus-4-8

# Cohere (embeddings + reranking)
COHERE_API_KEY=...
EMBED_MODEL=embed-english-v3.0
RERANK_MODEL=rerank-english-v3.0

# Retrieval tuning
# How many chunks to pull from the vector store before reranking.
RETRIEVAL_K=20
# How many reranked chunks to actually feed the model.
RERANK_TOP_N=5
# Set to false to skip Cohere rerank and use raw vector similarity.
USE_RERANK=true

# Storage locations (relative to the backend/ dir)
PAPERS_DIR=data/papers
CHROMA_DIR=data/chroma
CHROMA_COLLECTION=gym_papers

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# CORS — comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:5173
